DOMAIN=example.com
HOST_IP=192.168.1.10
DNS_UPSTREAM=1.1.1.1
DNS_AUTHORITATIVE=true

# ACME DNS-01 challenge support (requires the acme-dns sidecar in compose)
# Set to true and keep the acme-dns service to enable DNS-01 certificate issuance.
ACME_DNS_ENABLED=false

# Reload / debounce intervals — tune for reactivity vs. CPU trade-off.
# HOSTS_RELOAD : how often CoreDNS re-reads /etc/coredns/hosts (CoreDNS duration, e.g. 5s, 1m)
# ZONE_RELOAD  : how often CoreDNS re-reads the static zone file
# DOCKERGEN_WAIT : docker-gen debounce window — min:max before rewriting the hosts file
HOSTS_RELOAD=15s
ZONE_RELOAD=30s
DOCKERGEN_WAIT=5s:30s
